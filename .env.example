# LLM Provider
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# HTTP API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Frontend build
VITE_API_BASE_URL=http://localhost:8000

# Douyin Source
DOUYIN_SOURCE_DIR=D:\BaiduNetdiskDownload\dy src
DOUYIN_SOURCE_HOST_DIR=D:\BaiduNetdiskDownload\dy src
AUDIO_OUTPUT_DIR=D:\BaiduNetdiskDownload\dy out

# Speech Recognition
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=
WHISPER_BEAM_SIZE=5
WHISPER_VAD_FILTER=true

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=echolens

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Vector Storage
VECTOR_DB=
